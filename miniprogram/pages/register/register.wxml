<view class="page">
  <view class="status-bar"></view>

  <view class="content">
    <text class="title">注册</text>

    <view class="form">
      <input
        class="input"
        placeholder="输入用户名"
        placeholder-class="input-placeholder"
        bindinput="onUsernameInput"
      />
      <input
        class="input"
        placeholder="输入密码"
        password="true"
        placeholder-class="input-placeholder"
        bindinput="onPasswordInput"
      />
      <input
        class="input"
        placeholder="再次输入密码"
        password="true"
        placeholder-class="input-placeholder"
        bindinput="onConfirmPasswordInput"
      />

      <view class="login-btn" bindtap="onRegisterTap">注册</view>

      <view class="register-row">
        <text class="register-text">已有账号?</text>
        <text class="register-link" bindtap="onGoLoginTap"> 直接登录</text>
      </view>
    </view>
  </view>

  <view class="footer safe-bottom">
    <text class="footer-text">
      登录/注册表示您同意《用户协议》和《隐私政策》
    </text>
  </view>
</view>

